{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Z-ID profile for Zentari users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["NGO", "donor", "citizen", "admin"], "description": "User role in the ecosystem" },
        "trust_score": { "type": "number", "description": "AI-calculated trust score (0-100)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "trust_score"]
    },
    "Project": {
      "title": "Impact Project",
      "description": "A project requiring impact verification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "status": { "type": "string", "enum": ["active", "completed", "paused"] },
        "owner_id": { "type": "string", "description": "UID of the NGO/Owner" }
      },
      "required": ["id", "title", "owner_id"]
    },
    "Evidence": {
      "title": "Impact Evidence",
      "description": "Raw evidence uploaded by users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "project_id": { "type": "string" },
        "storage_path": { "type": "string", "description": "Path in Firebase Storage" },
        "metadata": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "verification_score": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "project_id", "storage_path"]
    },
    "PoI": {
      "title": "Proof of Impact",
      "description": "Verified impact record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "evidence_id": { "type": "string" },
        "user_id": { "type": "string" },
        "project_id": { "type": "string" },
        "poi_score": { "type": "number" },
        "verification_data": { "type": "object" },
        "block_number": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "evidence_id", "poi_score"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "projects": { "schema": "Project", "description": "Impact projects" },
    "evidence": { "schema": "Evidence", "description": "Evidence submissions" },
    "poi_records": { "schema": "PoI", "description": "Verified PoI records" }
  }
}
