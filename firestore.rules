rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User's name
    //   - role: string (required) - NGO, donor, citizen, admin
    //   - trust_score: number (required) - AI-calculated trust score
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required) - Project ID
    //   - title: string (required) - Project title
    //   - owner_id: string (required) - UID of the NGO/Owner
    //   - status: string (required) - active, completed, paused
    //
    // Collection: evidence
    // Document ID: {evidenceId}
    // Fields:
    //   - id: string (required) - Evidence ID
    //   - user_id: string (required) - UID of the uploader
    //   - project_id: string (required) - Project ID
    //   - storage_path: string (required) - Path in Firebase Storage
    //   - status: string (required) - pending, verified, rejected
    //
    // Collection: poi_records
    // Document ID: {poiId}
    // Fields:
    //   - id: string (required) - PoI ID
    //   - evidence_id: string (required) - Evidence ID
    //   - user_id: string (required) - UID of the uploader
    //   - poi_score: number (required) - Calculated PoI score
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "pulse3907@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['NGO', 'donor', 'citizen', 'admin'] &&
             data.trust_score is number && data.trust_score >= 0 && data.trust_score <= 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 128));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && 
                        request.resource.data.role == resource.data.role && 
                        request.resource.data.trust_score == resource.data.trust_score) || isAdmin();
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAuthenticated() && (request.auth.uid == request.resource.data.owner_id || isAdmin());
      allow delete: if isAdmin();
    }

    // Evidence collection
    match /evidence/{evidenceId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAdmin(); // Only admins/AI can update status
    }

    // PoI records collection
    match /poi_records/{poiId} {
      allow read: if true; // PoI is public for transparency
      allow create, update: if isAdmin(); // Only system/admin can generate PoI
    }
  }
}
